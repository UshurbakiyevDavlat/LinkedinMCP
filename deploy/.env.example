# LinkedIn OAuth token (required)
# Get it from: https://www.linkedin.com/developers/tools/oauth/token-inspector
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# MCP transport mode: "sse" for VPS/remote, "stdio" for local Claude Desktop
MCP_TRANSPORT=sse

# Port for SSE server (default: 3100)
PORT=3100

# Auth token for /sse endpoint (recommended: generate a random string)
# Clients must pass ?token=... in the SSE URL
MCP_AUTH_TOKEN=your_random_secret_token_here
